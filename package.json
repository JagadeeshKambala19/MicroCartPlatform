  "scripts": {
    "db:up": "docker compose up -d mysql",
    "prepare": "husky",
    "db:down": "docker compose down",
    "dev": "concurrently -k -n auth,product,cart,order,web -c cyan,magenta,green,yellow,blue \"npm run dev --workspace services/auth-service\" \"npm run dev --workspace services/product-service\" \"npm run dev --workspace services/cart-service\" \"npm run dev --workspace services/order-service\" \"npm run dev --workspace frontend\"",
    "start": "concurrently -k -n auth,product,cart,order -c cyan,magenta,green,yellow \"npm run start --workspace services/auth-service\" \"npm run start --workspace services/product-service\" \"npm run start --workspace services/cart-service\" \"npm run start --workspace services/order-service\"",
    "zip:from-output": "bash create-zip.sh project.txt"
  },
